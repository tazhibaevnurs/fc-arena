# Скопируйте в .env и заполните для отправки писем (подтверждение регистрации).
# Без этих переменных письма выводятся в консоль (режим разработки).

# --- Django (production / local) ---
SECRET_KEY=
DJANGO_DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
# Для production: DJANGO_DEBUG=0, ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Опционально (Docker): DATABASE_URL=postgres://fc26:fc26@db:5432/fc26
# POSTGRES_USER=fc26
# POSTGRES_PASSWORD=fc26
# POSTGRES_DB=fc26
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000

# --- Gmail: обязательно используйте ПАРОЛЬ ПРИЛОЖЕНИЯ, не обычный пароль! ---
# 1. Включите двухфакторную аутентификацию: https://myaccount.google.com/security
# 2. Пароли приложений: https://myaccount.google.com/apppasswords
#    (или: Безопасность → Вход в Google → Пароли приложений)
# 3. Создайте пароль для «Почта» / «Mail», скопируйте 16 символов без пробелов
# 4. Вставьте ниже в EMAIL_HOST_PASSWORD

# SMTP-сервер (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true

EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx

DEFAULT_FROM_EMAIL=your-email@gmail.com

# --- 2Checkout (опционально) ---
# TWOCHECKOUT_SID=
# TWOCHECKOUT_SECRET_WORD=
# TWOCHECKOUT_DEMO=1

# --- Robokassa (опционально) ---
# ROBOKASSA_LOGIN=
# ROBOKASSA_PASSWORD1=
# ROBOKASSA_PASSWORD2=
# ROBOKASSA_TEST=1

# --- Аналитика воронки подписки (опционально) ---
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# YANDEX_METRIKA_ID=12345678

# --- Кэш (production: общий для воркеров) ---
# REDIS_URL=redis://127.0.0.1:6379/0
